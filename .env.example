# ============================================================
# ACity RAG Chatbot — Environment Variables Template
# Name: Hansen Donkor  |  Index Number: 10012200059
#
# Copy this to .env for local development:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)
#
# For Streamlit Cloud deployment: add secrets via the
# Streamlit Cloud web UI (Settings → Secrets), NOT here.
# ============================================================

STUDENT_NAME=Hansen Donkor
INDEX_NUMBER=10012200059

# ── LLM Provider ─────────────────────────────────────────────
LLM_PROVIDER=vertex

# ── Vertex AI / Google Cloud ──────────────────────────────────
PROJECT_ID=intro-to-ai-494310
LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# ── Local authentication (one of the two options below) ──────
#
# Option A — Point to your service account JSON file (recommended for local dev):
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-service-account-key.json
#
# Option B — Use gcloud Application Default Credentials:
# Run: gcloud auth application-default login
# (leave GOOGLE_APPLICATION_CREDENTIALS unset)

# ── App tuning (optional overrides) ──────────────────────────
# CHUNK_SIZE_CHARS=1200
# CHUNK_OVERLAP_CHARS=200
# TOP_K=12
# W_VECTOR=0.60
# W_KEYWORD=0.25
# W_DOMAIN=0.15
# MAX_CONTEXT_TOKENS=1800
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# PDF_ENGINE=pymupdf
# LOG_LEVEL=INFO
